    "eval:workspace-eval-initial-prompt": "./scripts/promptfoo.sh eval --no-cache -c packages/workspace-eval-initial-prompt/promptfooconfig.json",
    "eval:workspace-description-evals-generator-prompt": "./scripts/promptfoo.sh eval --no-cache -c packages/workspace-description-evals-generator-prompt/promptfooconfig.json",
    "eval:scope-advisor": "./scripts/promptfoo.sh eval --no-cache -c packages/scope-advisor/promptfooconfig.json",
