{
  "name": "@skill-builder/evals",
  "private": true,
  "description": "Promptfoo eval harness for Skill Builder agent behavior",
  "scripts": {
    "eval:harness-smoke": "node bin/ad-evals.js run packages/harness-smoke/promptfooconfig.json",
    "eval:skill-content-researcher-research": "node bin/ad-evals.js run packages/skill-content-researcher-research/promptfooconfig.json",
    "eval:skill-content-researcher-answer-evaluator": "node bin/ad-evals.js run packages/skill-content-researcher-answer-evaluator/promptfooconfig.json",
    "eval:skill-content-researcher-detailed-research": "node bin/ad-evals.js run packages/skill-content-researcher-detailed-research/promptfooconfig.json",
    "eval:skill-content-researcher-confirm-decisions": "node bin/ad-evals.js run packages/skill-content-researcher-confirm-decisions/promptfooconfig.json",
    "eval:skill-creator-generate-skill": "node bin/ad-evals.js run packages/skill-creator-generate-skill/promptfooconfig.json",
    "eval:skill-creator-rewrite-skill": "node bin/ad-evals.js run packages/skill-creator-rewrite-skill/promptfooconfig.json",
    "eval:skill-creator-grader": "node bin/ad-evals.js run packages/skill-creator-grader/promptfooconfig.json",
    "eval:workspace-test-evaluator-prompt": "node bin/ad-evals.js run packages/workspace-test-evaluator-prompt/promptfooconfig.json",
    "eval:workspace-workflow-step-prompt": "node bin/ad-evals.js run packages/workspace-workflow-step-prompt/promptfooconfig.json",
    "eval:workspace-eval-generator-system-prompt": "node bin/ad-evals.js run packages/workspace-eval-generator-system-prompt/promptfooconfig.json",
    "eval:workspace-eval-workbench-suggest-scenario-prompt": "node bin/ad-evals.js run packages/workspace-eval-workbench-suggest-scenario-prompt/promptfooconfig.json",
    "eval:workspace-skill-suggestions-prompt": "node bin/ad-evals.js run packages/workspace-skill-suggestions-prompt/promptfooconfig.json",
    "eval:scope-advisor": "node bin/ad-evals.js run packages/scope-advisor/promptfooconfig.json",
    "eval:agents": "node bin/ad-evals.js run packages/skill-content-researcher-research/promptfooconfig.json && node bin/ad-evals.js run packages/skill-content-researcher-answer-evaluator/promptfooconfig.json && node bin/ad-evals.js run packages/skill-content-researcher-detailed-research/promptfooconfig.json && node bin/ad-evals.js run packages/skill-content-researcher-confirm-decisions/promptfooconfig.json && node bin/ad-evals.js run packages/skill-creator-generate-skill/promptfooconfig.json && node bin/ad-evals.js run packages/skill-creator-rewrite-skill/promptfooconfig.json && node bin/ad-evals.js run packages/skill-creator-grader/promptfooconfig.json",
    "eval:regression": "node bin/ad-evals.js regression",
    "eval:smoke": "node bin/ad-evals.js smoke",
    "test": "node bin/ad-evals.js test",
    "test:harness": "node --test scripts/*.test.js scripts/framework/*.test.js",
    "test:assertions": "node --test assertions/*.test.js",
    "doctor": "node bin/ad-evals.js doctor",
    "view": "node bin/ad-evals.js view"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "promptfoo": "0.121.11",
    "smol-toml": "^1.6.1",
    "typescript": "~6.0.2"
  },
  "overrides": {
    "@anthropic-ai/sdk": ">=0.91.1",
    "uuid": "^14.0.0",
    "protobufjs": "8.2.0"
  }
}
