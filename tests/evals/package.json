{
  "name": "@skill-builder/evals",
  "private": true,
  "description": "Promptfoo eval harness for Skill Builder agent behavior",
  "scripts": {
    "eval:agents": "./scripts/promptfoo.sh eval --no-cache -c packages/agent-contracts/promptfooconfig.json",
    "eval:scope-advisor": "./scripts/promptfoo.sh eval --no-cache -c packages/scope-advisor/promptfooconfig.json",
    "eval:smoke": "./scripts/promptfoo.sh eval --no-cache --filter-pattern '^\\[smoke\\]' -c packages/agent-contracts/promptfooconfig.json -c packages/scope-advisor/promptfooconfig.json",
    "test": "node --test scripts/*.test.js assertions/*.test.js",
    "test:harness": "node --test scripts/*.test.js",
    "test:assertions": "node --test assertions/*.test.js",
    "view": "./scripts/promptfoo.sh view"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "promptfoo": "0.121.9",
    "smol-toml": "^1.6.1"
  },
  "overrides": {
    "@anthropic-ai/sdk": ">=0.81.0"
  }
}
