    "eval:skill-creator-generate-skill": "./scripts/promptfoo.sh eval --no-cache -c packages/skill-creator-generate-skill/promptfooconfig.json",
    "eval:skill-creator-rewrite-skill": "./scripts/promptfoo.sh eval --no-cache -c packages/skill-creator-rewrite-skill/promptfooconfig.json",
