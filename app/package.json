{
  "name": "app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "devtools": "react-devtools",
    "dev": "node scripts/dev.mjs",
    "dev:frontend": "vite",
    "dev:test": "cross-env TAURI_E2E=true TAURI_DEV_HOST=127.0.0.1 vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "codegen": "cargo run --manifest-path src-tauri/Cargo.toml --bin codegen",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/__tests__/stores/ src/__tests__/lib/ src/__tests__/hooks/",
    "test:guard": "vitest run src/__tests__/guards/",
    "test:integration": "vitest run src/__tests__/components/ src/__tests__/pages/",
    "test:e2e": "playwright test --project smoke",
    "test:e2e:dashboard": "playwright test --grep @dashboard",
    "test:e2e:settings": "playwright test --grep @settings",
    "test:e2e:workflow": "playwright test --grep '@workflow|@workflow-agent'",
    "test:e2e:navigation": "playwright test --grep @navigation",
    "test:e2e:skills": "playwright test --grep @skills",
    "test:e2e:usage": "playwright test --grep @usage",
    "test:e2e:integration": "playwright test --grep @integration",
    "test:changed": "vitest run --changed HEAD~1",
    "test:agents": "npm run test:agents:structural && npm run test:agents:smoke",
    "test:agents:structural": "vitest run --config vitest.config.agent.ts agent-tests/agent-structure.test.ts",
    "test:agents:smoke": "cd ../tests/evals && npm run eval:agents",
    "test:repo-map": "node --test ../scripts/ci/verify-repo-map.test.mjs && node ../scripts/ci/verify-repo-map.mjs ..",
    "test:scope-advisor:smoke": "cd ../tests/evals && npm run eval:scope-advisor",
    "test:evals:harness": "cd ../tests/evals && npm test",
    "test:openhands:live-smoke": "node ../scripts/smoke/openhands-agent-server-live-smoke.mjs",
    "test:openhands:agentskill-smoke": "node ../scripts/smoke/openhands-agentskill-live-smoke.mjs",
    "test:openhands:subagent-smoke": "node ../scripts/smoke/openhands-subagent-live-smoke.mjs",
    "test:litellm:live-smoke": "node ../scripts/smoke/litellm-proxy-live-smoke.mjs",
    "test:all": "npm run test:unit && npm run test:guard && npm run test:integration && npm run test:e2e"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.169.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2",
    "@testing-library/dom": "^10.4.1",
    "@tiptap/extension-mention": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/pm": "^3.21.0",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.4",
    "@tiptap/suggestion": "^3.23.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "github-markdown-css": "^5.9.0",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.0",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "fast-xml-parser": ">=5.7.2",
    "uuid": "^14.0.0"
  }
}
