# macOS
.DS_Store

# Dependencies
node_modules/

# Allow mock-template context/ dirs (bundled test fixtures, not user output)
!app/sidecar/mock-templates/**/context/

# Test results
app/test-results/
app/src-tauri/test-results/
app/playwright-report/
app/playwright-artifacts/

# VitePress build output
docs/.vitepress/dist/

# Bundled Node.js binary (downloaded during CI build, not committed)
app/src-tauri/resources/node/*
!app/src-tauri/resources/node/.gitkeep

# Claude Code — ignore local config, track committed skills
.claude/worktrees/

# Git worktrees (local development isolation)
.worktrees/

# Local screenshots (not committed)
screenshots-gitignore/

# Vibedata agent artifacts 
vd-memory/*

