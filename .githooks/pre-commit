#!/bin/sh
# Prevent committing secrets from local Claude settings.

set -eu

ANT_KEY_PAT="sk-ant"
ANT_KEY_PAT="${ANT_KEY_PAT}-"
staged_files="$(git diff --cached --name-only)"

# Block Anthropic API keys in staged files, but scan .mcp.json for key
# values rather than blocking the whole file.
files_to_scan=""
if [ -n "$staged_files" ]; then
  for f in $staged_files; do
    if [ "$f" = ".mcp.json" ]; then
      # Only flag .mcp.json if it contains an actual API key value.
      if git show ":0:.mcp.json" 2>/dev/null | grep -q "$ANT_KEY_PAT"; then
        echo "ERROR: Anthropic API key detected in .mcp.json." >&2
        echo "Remove the key value before committing." >&2
        exit 1
      fi
    else
      files_to_scan="$files_to_scan $f"
    fi
  done
fi

if [ -n "$files_to_scan" ] && echo "$files_to_scan" | xargs grep -l "$ANT_KEY_PAT" 2>/dev/null | grep -q .; then
  echo "ERROR: Anthropic API key detected in staged files." >&2
  echo "Remove the key before committing." >&2
  echo "$files_to_scan" | xargs grep -l "$ANT_KEY_PAT" 2>/dev/null | while read -r f; do
    echo "  $f" >&2
  done
  exit 1
fi

# Block real key in committed .claude/settings.local.json
if echo "$staged_files" | grep -q "^\.claude/settings\.local\.json$"; then
  key=$(git show :0:.claude/settings.local.json \
    | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('env',{}).get('ANTHROPIC_API_KEY',''))" \
    2>/dev/null || true)
  if [ -n "$key" ] && [ "$key" != "YOUR_API_KEY_HERE" ]; then
    echo "ERROR: .claude/settings.local.json contains a real ANTHROPIC_API_KEY." >&2
    echo "Reset it to YOUR_API_KEY_HERE before committing." >&2
    exit 1
  fi
fi
