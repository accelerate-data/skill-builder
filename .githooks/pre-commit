#!/bin/sh
# Prevent committing secrets from local Claude settings.

set -eu

staged_files="$(git diff --cached --name-only)"

# Patterns that identify real API key values.
# Split across assignments so the hook doesn't trigger on itself.
ANT_PAT="sk-ant"; ANT_PAT="${ANT_PAT}-"         # Anthropic
OAI_PAT="sk-proj"; OAI_PAT="${OAI_PAT}-"        # OpenAI project key
OAI_OLD="sk-"; OAI_OLD="${OAI_OLD}T3BlbkFJ"     # OpenAI legacy key
GH_PAT="ghp_"                                    # GitHub personal access token
GH_APP="ghs_"                                    # GitHub app token
LINEAR_PAT="lin_api_"                            # Linear API key
SLACK_PAT="xoxb-"                                # Slack bot token
SLACK_USR="xoxp-"                                # Slack user token

contains_secret() {
  content="$1"
  echo "$content" | grep -qE \
    "${ANT_PAT}|${OAI_PAT}|${OAI_OLD}|${GH_PAT}|${GH_APP}|${LINEAR_PAT}|${SLACK_PAT}|${SLACK_USR}"
}

# Scan .mcp.json for secret values rather than blocking the whole file.
# All other staged files are scanned directly.
files_to_scan=""
if [ -n "$staged_files" ]; then
  for f in $staged_files; do
    if [ "$f" = ".mcp.json" ]; then
      content="$(git show ":0:.mcp.json" 2>/dev/null || true)"
      if contains_secret "$content"; then
        echo "ERROR: API key detected in .mcp.json — remove the value before committing." >&2
        exit 1
      fi
    else
      files_to_scan="$files_to_scan $f"
    fi
  done
fi

if [ -n "$files_to_scan" ]; then
  flagged="$(echo "$files_to_scan" | xargs grep -lE \
    "${ANT_PAT}|${OAI_PAT}|${OAI_OLD}|${GH_PAT}|${GH_APP}|${LINEAR_PAT}|${SLACK_PAT}|${SLACK_USR}" \
    2>/dev/null || true)"
  if [ -n "$flagged" ]; then
    echo "ERROR: API key detected in staged files — remove the key before committing." >&2
    echo "$flagged" | while read -r f; do echo "  $f" >&2; done
    exit 1
  fi
fi

# Block real key in committed .claude/settings.local.json
if echo "$staged_files" | grep -q "^\.claude/settings\.local\.json$"; then
  key=$(git show :0:.claude/settings.local.json \
    | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('env',{}).get('ANTHROPIC_API_KEY',''))" \
    2>/dev/null || true)
  if [ -n "$key" ] && [ "$key" != "YOUR_API_KEY_HERE" ]; then
    echo "ERROR: .claude/settings.local.json contains a real ANTHROPIC_API_KEY." >&2
    echo "Reset it to YOUR_API_KEY_HERE before committing." >&2
    exit 1
  fi
fi
