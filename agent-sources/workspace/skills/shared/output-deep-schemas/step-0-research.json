{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ResearchStepOutput",
  "description": "Structured output produced by the OpenHands research workflow step.",
  "additionalProperties": false,
  "type": "object",
  "required": ["status", "dimensions_selected", "question_count", "research_output"],
  "properties": {
    "status": { "type": "string" },
    "dimensions_selected": { "type": "integer", "format": "int64" },
    "question_count": { "type": "integer", "format": "int64" },
    "research_output": { "$ref": "#/$defs/ClarificationsFile" }
  },
  "$defs": {
    "ClarificationsFile": {
      "description": "Root type for a clarifications file.",
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "version": { "type": "string", "default": "" },
        "metadata": { "$ref": "#/$defs/ClarificationsMetadata" },
        "sections": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/Section" }
        },
        "notes": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/Note" }
        },
        "answer_evaluator_notes": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/Note" }
        }
      }
    },
    "ClarificationsMetadata": {
      "description": "Metadata block with counts, priority questions, and optional scope/research info.",
      "additionalProperties": false,
      "type": "object",
      "default": {
        "title": "",
        "question_count": 0,
        "section_count": 0,
        "refinement_count": 0,
        "must_answer_count": 0,
        "priority_questions": []
      },
      "properties": {
        "title": { "type": "string", "default": "" },
        "question_count": { "type": "integer", "format": "int64", "default": 0 },
        "section_count": { "type": "integer", "format": "int64", "default": 0 },
        "refinement_count": { "type": "integer", "format": "int64", "default": 0 },
        "must_answer_count": { "type": "integer", "format": "int64", "default": 0 },
        "priority_questions": {
          "type": "array",
          "default": [],
          "items": { "type": "string" }
        },
        "duplicates_removed": { "type": ["integer", "null"], "format": "int64" },
        "scope_recommendation": { "type": ["boolean", "null"] },
        "scope_reason": { "type": ["string", "null"] },
        "scope_next_action": { "type": ["string", "null"] },
        "research_plan": {
          "anyOf": [
            { "$ref": "#/$defs/ResearchPlan" },
            { "type": "null" }
          ]
        },
        "warning": {
          "anyOf": [
            { "$ref": "#/$defs/Warning" },
            { "type": "null" }
          ]
        },
        "error": {
          "anyOf": [
            { "$ref": "#/$defs/Error" },
            { "type": "null" }
          ]
        }
      }
    },
    "ResearchPlan": {
      "description": "Research plan with dimension scoring.",
      "additionalProperties": false,
      "type": "object",
      "required": ["purpose", "domain", "topic_relevance"],
      "properties": {
        "purpose": { "type": "string" },
        "domain": { "type": "string" },
        "topic_relevance": { "type": "string" },
        "dimensions_evaluated": { "type": "integer", "format": "int64", "default": 0 },
        "dimensions_selected": { "type": "integer", "format": "int64", "default": 0 },
        "dimension_scores": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/DimensionScore" }
        },
        "selected_dimensions": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/SelectedDimension" }
        }
      }
    },
    "DimensionScore": {
      "description": "A scored dimension in the research plan.",
      "additionalProperties": false,
      "type": "object",
      "required": ["name", "score", "reason", "focus"],
      "properties": {
        "name": { "type": "string" },
        "score": { "type": "number", "format": "double" },
        "reason": { "type": "string" },
        "focus": { "type": "string" }
      }
    },
    "SelectedDimension": {
      "description": "A dimension selected for deeper research.",
      "additionalProperties": false,
      "type": "object",
      "required": ["name", "focus"],
      "properties": {
        "name": { "type": "string" },
        "focus": { "type": "string" }
      }
    },
    "Section": {
      "description": "A section grouping related questions.",
      "additionalProperties": false,
      "type": "object",
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "integer", "format": "int64" },
        "title": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "questions": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/Question" }
        }
      }
    },
    "Question": {
      "description": "A question with choices and optional answer fields. Recursive via refinements.",
      "additionalProperties": false,
      "type": "object",
      "required": ["id", "title", "text", "must_answer"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "text": { "type": "string" },
        "must_answer": { "type": "boolean" },
        "choices": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/Choice" }
        },
        "recommendation": { "type": ["string", "null"] },
        "answer_choice": { "type": ["string", "null"] },
        "answer_text": { "type": ["string", "null"] },
        "consolidated_from": { "type": ["array", "null"], "items": { "type": "string" } },
        "refinements": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/Question" }
        }
      }
    },
    "Choice": {
      "description": "A multiple-choice option.",
      "additionalProperties": false,
      "type": "object",
      "required": ["id", "text", "is_other"],
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "is_other": { "type": "boolean" }
      }
    },
    "Note": {
      "description": "A note (research note or evaluator feedback).",
      "additionalProperties": false,
      "type": "object",
      "required": ["type", "title", "body"],
      "properties": {
        "type": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" }
      }
    },
    "Warning": {
      "description": "Warning attached to metadata.",
      "additionalProperties": false,
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "Error": {
      "description": "Error attached to metadata.",
      "additionalProperties": false,
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
